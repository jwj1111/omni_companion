# DashScope API Key（必填）
DASHSCOPE_API_KEY=sk-your-api-key

# Realtime 可选独立 Key；留空时后端会复用 DASHSCOPE_API_KEY
# DASHSCOPE_API_KEY_REALTIME=sk-your-realtime-api-key

# beijing 或 singapore
API_REGION=beijing

# 前端生产构建默认走同域 Nginx 反代，无需配置。
# 若前后端分域部署，可在构建前设置：
# VITE_API_BASE_URL=https://your-api.example.com
# VITE_WS_BASE_URL=wss://your-api.example.com/api/realtime/ws
